# Photobooth Platform — Environment Variables
# Copy to .env and fill in your values

# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE-ME

# SMTP (AhaSend)
SMTP_HOST=send.ahasend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@mycreativity.nl

# URLs (production)
SERVER_URL=https://api.mycreativity.nl
ADMIN_URL=https://admin.mycreativity.nl
WS_URL=wss://api.mycreativity.nl

# URLs (local dev — uncomment these, comment out production URLs above)
# SERVER_URL=http://localhost:8000
# ADMIN_URL=http://localhost:3000
# WS_URL=ws://localhost:8000

# Admin seed user
ADMIN_EMAIL=steenweg@gmail.com
