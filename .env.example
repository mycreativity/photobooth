# Photobooth Platform — Environment Variables
# Copy to .env and fill in your values

# JWT Secret (generate a random string: openssl rand -hex 32)
JWT_SECRET=CHANGE-ME

# SMTP (AhaSend)
SMTP_HOST=send.ahasend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@mycreativity.nl

# URLs
SERVER_URL=https://api.mycreativity.nl
ADMIN_URL=https://admin.mycreativity.nl
WS_URL=wss://api.mycreativity.nl

# Admin
ADMIN_EMAIL=steenweg@gmail.com
