# Production Dockerfile for API (non-editable install)
FROM python:3.12-slim

WORKDIR /app

# Copy source
COPY pyproject.toml .
COPY src/ src/

# Install in non-editable mode for production
RUN pip install --no-cache-dir --upgrade pip setuptools && \
    pip install --no-cache-dir .

# Create data directory
RUN mkdir -p /data/photos

EXPOSE 8000

CMD ["python", "-m", "api"]
